{
    "luci-theme-proton2025": {
        "description": "Proton2025 theme - temperature sensor, setting access, and services monitoring",
        "read": {
            "ubus": {
                "luci.proton-temp": [
                    "getSensors",
                    "resetPeaks"
                ],
                "luci.proton-system": [
                    "getSystemInfo"
                ],
                "luci.proton-search-cache": [
                    "loadCache"
                ],
                "luci.proton-settings": [
                    "getSettings",
                    "getVersion",
                    "checkUpdate"
                ],
                "network.interface": [
                    "dump"
                ],
                "luci-rpc": [
                    "getDHCPLeases"
                ]
            },
            "uci": [
                "proton2025",
                "network",
                "wireless",
                "dhcp"
            ],
            "file": {
                "/etc/init.d/*": [
                    "exec"
                ],
                "/bin/pidof": [
                    "exec"
                ]
            }
        },
        "write": {
            "ubus": {
                "luci.proton-settings": [
                    "setSetting",
                    "setSettings",
                    "resetSettings",
                    "installUpdate"
                ],
                "luci.proton-search-cache": [
                    "saveCache",
                    "clearCache"
                ]
            },
            "uci": [
                "proton2025"
            ]
        }
    }
}